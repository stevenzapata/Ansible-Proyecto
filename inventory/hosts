[all:vars]
ansible_python_interpreter=/usr/bin/python3

[local]
localhost ansible_connection=local

[linux]
# ansible_user: usuario de gestión que debe existir en la máquina destino con acceso SSH y permisos sudo
CliLin ansible_host=YOUR_HOST_IP ansible_user=stevenz

[linux:vars]
ansible_connection=ssh

[windows]
# ansible_user: usuario de gestión que debe existir en la máquina destino con acceso SSH y permisos de administrador
CliWin ansible_host=YOUR_HOST_IP ansible_user=stevenz
SrvWin ansible_host=YOUR_HOST_IP ansible_user=stevenz

[windows:vars]
ansible_connection=winrm
ansible_shell_type=powershell
ansible_port=5985
